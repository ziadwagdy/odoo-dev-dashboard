# Copy to .env and fill in your values
REGISTRY_FILE=/srv/odoo-dev/projects/.port-registry
ODOO_DEV_BASE=/srv/odoo-dev
BASE_DOMAIN=your-domain.example.com
LOGS_URL=https://logs.your-domain.example.com
FILES_URL=https://files.your-domain.example.com
TERMINAL_URL=https://terminal.your-domain.example.com
DASHBOARD_TITLE=Odoo Dev Dashboard
PORT=8892
# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.example.com
DB_USER=odoo
DB_PASSWORD=odoo
# Generate with: python3 -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=change-me-to-a-long-random-string
